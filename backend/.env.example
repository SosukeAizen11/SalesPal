# ─── Server ──────────────────────────────────────────────────────────────────
# Port the Express server listens on. Cloud Run injects this automatically.
PORT=8080

# Environment: 'development' | 'production'
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# Cloud SQL PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For Cloud Run with Unix socket: postgresql://USER:PASSWORD@/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=salespal
DB_PASSWORD=your_db_password_here
DB_NAME=salespal
DB_SSL=false

# Cloud SQL instance connection name (used by Cloud Run with Cloud SQL Proxy)
# Format: project-id:region:instance-name
CLOUD_SQL_CONNECTION_NAME=your-project:us-central1:salespal-db

# Maximum number of clients in the PostgreSQL connection pool
DB_POOL_MAX=20

# ─── Authentication ──────────────────────────────────────────────────────────
# Secret key for signing JWT access tokens (256-bit minimum recommended)
JWT_ACCESS_SECRET=your_jwt_access_secret_here_change_in_production

# Secret key for signing JWT refresh tokens (should differ from access secret)
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_change_in_production

# Access token TTL in seconds (default: 900 = 15 minutes)
JWT_ACCESS_TTL=900

# Refresh token TTL in seconds (default: 604800 = 7 days)
JWT_REFRESH_TTL=604800

# Bcrypt salt rounds for password hashing
BCRYPT_SALT_ROUNDS=12

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ─── AI Service ──────────────────────────────────────────────────────────────
# External AI API endpoint (e.g., OpenAI, Google AI, etc.)
AI_API_URL=https://api.openai.com/v1/chat/completions

# API key for the AI service
AI_API_KEY=your_ai_api_key_here

# AI model to use
AI_MODEL=gpt-4o-mini

# ─── Social Media Integrations ───────────────────────────────────────────────
# Facebook/Meta App credentials
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Maximum requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ─────────────────────────────────────────────────────────────────
# Log level: error | warn | info | http | debug
LOG_LEVEL=info
